# Development Dockerfile for React + Vite frontend
# This uses Node.js 20 LTS (Alpine for smaller image size)

FROM node:20-alpine

# Set working directory inside container
WORKDIR /app

# Copy package files first (for Docker layer caching)
# If package.json doesn't change, npm install layer will be cached
COPY package*.json ./

# Install dependencies
# --silent: reduce npm install output noise
RUN npm install --silent

# Copy application code
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Start Vite dev server
# --host: Listen on all network interfaces (needed for Docker)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
