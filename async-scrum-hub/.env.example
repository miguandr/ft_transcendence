# ====================================
# ASYNC SCRUM HUB - ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env and update values for local development
# DO NOT commit .env to version control!

# ====================================
# DATABASE CONFIGURATION
# ====================================
DB_USER=scrumadmin
DB_PASSWORD=dev_password_123
DB_HOST=postgres  # Use 'postgres' in Docker, 'localhost' for local dev
DB_PORT=5432
DB_NAME=async_scrum_hub

# ====================================
# BACKEND CONFIGURATION
# ====================================
# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# API Configuration
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000

# ====================================
# EMAIL / SMTP CONFIGURATION
# ====================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=justspamandegg@gmail.com
SMTP_PASSWORD=vgki qgrc bxbd tgpe
SMTP_FROM_EMAIL=Async Scrum Hub

# ====================================
# FRONTEND CONFIGURATION
# ====================================
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173

# ====================================
# DEVELOPMENT SETTINGS
# ====================================
# Set to 'development' for local dev, 'production' for deployment
ENVIRONMENT=development

# Python settings (for backend)
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
