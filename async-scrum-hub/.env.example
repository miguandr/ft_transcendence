# ====================================
# ASYNC SCRUM HUB - ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env and update values for local development

# ====================================
# DATABASE CONFIGURATION
# ====================================
DB_USER=scrumadmin
DB_PASSWORD=dev_password_123
DB_PORT=5432
DB_NAME=async_scrum_hub

# ====================================
# BACKEND CONFIGURATION
# ====================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# ====================================
# EMAIL / SMTP CONFIGURATION
# ====================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=justspamandegg@gmail.com
SMTP_PASSWORD=your-api-key-here-change-in-production
SMTP_FROM_EMAIL=Async Scrum Hub

# ====================================
# FRONTEND CONFIGURATION
# ====================================
# Set to your machine's local IP to access from other devices (e.g. 192.168.1.x).
# Leave as 'localhost' for single-machine development.
HOST_IP=localhost
